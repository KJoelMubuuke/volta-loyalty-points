<?xml version="1.0"?>
<ruleset name="Volta Loyalty Points">
    <description>WordPress coding standards for the Volta Loyalty Points plugin.</description>

    <file>.</file>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="WordPress"/>

    <config name="minimum_supported_wp_version" value="6.0"/>
    <config name="text_domain" value="volta-loyalty-points"/>
</ruleset>
